# ── Supabase (Frontend) ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Supabase (Server / Admin) ─────────────────────────────────────────────────
# Used by Express OTP server to create Supabase users after phone verification
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── OTP Security ──────────────────────────────────────────────────────────────
# Secret used to generate deterministic passwords from phone numbers.
# Change this to any random 32+ character string in production.
OTP_JWT_SECRET=change-me-to-a-random-secret-in-production

# ── SMS Provider ─────────────────────────────────────────────────────────────
# Firebase Phone Auth handles OTP SMS automatically.
# No additional SMS API key needed — configured via Firebase console.
# Firebase project: igobuyback-6d1a2 (config is hardcoded in src/lib/firebase.ts)

# ── Express OTP Server ────────────────────────────────────────────────────────
OTP_SERVER_PORT=3001

# ── Optional ──────────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=your-gemini-api-key
