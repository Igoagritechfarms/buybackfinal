SMS_OTP_TEMPLATE=IGO verification code: {{OTP}}. This code is valid for 5 minutes.

# Optional server-side OTP test mode
OTP_TEST_MODE=false
OTP_TEST_PHONE=1234567890
OTP_TEST_OTP=123456

# Optional local OTP validation bypass for testing
VITE_OTP_TEST_MODE=false
VITE_OTP_TEST_PHONE=1234567890
