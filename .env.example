# Supabase (frontend)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase (backend API routes / local OTP app)
# Vercel can use VITE_SUPABASE_URL directly, but keeping SUPABASE_URL
# also supports the local Express OTP server.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OTP security
OTP_JWT_SECRET=change-me-to-a-random-secret-in-production

# Local OTP server only
OTP_SERVER_PORT=3001

# Optional SMS provider for real OTP delivery
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Optional frontend integrations
VITE_GEMINI_API_KEY=your-gemini-api-key
